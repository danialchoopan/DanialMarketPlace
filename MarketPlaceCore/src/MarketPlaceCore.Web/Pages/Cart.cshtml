@page
@model MarketPlaceCore.Web.Pages.CartModel
@{
    ViewData["Title"] = "سبد خرید";
}

<div class="mb-8">
    <h2 class="text-3xl font-bold">سبد خرید</h2>
    <p class="opacity-70">مدیریت اقلام انتخاب شده و نهایی‌سازی سفارش</p>
</div>

<div class="flex flex-col lg:flex-row gap-8">
    <div class="w-full lg:w-2/3">
        <div id="cart-items-container" class="space-y-4">
            <!-- Items injected by JS -->
        </div>
    </div>

    <div class="w-full lg:w-1/3">
        <!-- Coupon Section -->
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700 mb-6 shadow-sm">
            <h3 class="font-bold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5 9 11l6 6"></path><path d="M19 12H5"></path></svg>
                کد تخفیف
            </h3>
            <div class="flex gap-2">
                <input type="text" id="coupon-code" placeholder="کد را وارد کنید" class="flex-1 bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-xl px-4 py-2 outline-none text-sm focus:border-primary">
                <button onclick="applyCoupon()" class="bg-gray-100 dark:bg-gray-700 px-6 py-2 rounded-xl font-bold hover:bg-gray-200 transition text-sm">اعمال</button>
            </div>
            <p id="coupon-msg" class="text-[10px] mt-2"></p>
        </div>

        <!-- Summary -->
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700 sticky top-24 shadow-lg">
            <h3 class="text-xl font-bold mb-6 border-b dark:border-gray-700 pb-4">خلاصه سفارش</h3>
            <div class="space-y-4 mb-6 text-sm">
                <div class="flex justify-between">
                    <span class="opacity-60">قیمت کالاها</span>
                    <span id="total-price">۰ تومان</span>
                </div>
                <div class="flex justify-between text-red-500 font-semibold" id="discount-row" style="display:none">
                    <span>سود شما از خرید</span>
                    <span id="discount-amount">۰ تومان</span>
                </div>
                <div class="border-t dark:border-gray-700 pt-4 flex justify-between font-black text-xl text-primary">
                    <span>مبلغ قابل پرداخت</span>
                    <span id="payable-price">۰ تومان</span>
                </div>
            </div>
            <button onclick="checkout()" id="checkout-btn" class="w-full bg-primary text-white py-4 rounded-xl font-bold shadow-lg hover:scale-[1.02] active:scale-95 transition">تایید و پرداخت</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let appliedDiscount = 0;
    let couponCode = "";

    function renderCart() {
        const cart = JSON.parse(localStorage.getItem('cart') || '[]');
        const container = document.getElementById('cart-items-container');

        if (cart.length === 0) {
            container.innerHTML = `
                <div class="bg-white dark:bg-gray-800 p-12 rounded-3xl border dark:border-gray-700 text-center">
                    <div class="text-6xl mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-gray-300"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                    </div>
                    <p class="text-xl font-bold mb-6">سبد خرید شما فعلاً خالی است!</p>
                    <a href="/Products" class="inline-block bg-primary text-white px-12 py-3 rounded-2xl font-bold">بازگشت به فروشگاه</a>
                </div>`;
            updateSummary(0);
            return;
        }

        let total = 0;
        container.innerHTML = cart.map(item => {
            total += item.price * item.quantity;
            return `
                <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700 flex items-center gap-6 shadow-sm">
                    <div class="w-24 h-24 bg-gray-50 dark:bg-gray-700 rounded-2xl flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-gray-300"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-lg">${item.name}</h4>
                        <p class="text-xs text-gray-400 mt-1">تنوع انتخابی: کد ${item.variantId}</p>
                        <div class="flex justify-between items-center mt-4">
                            <div class="flex items-center gap-4 bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-xl px-3 py-1.5">
                                <button onclick="changeQty(${item.variantId}, 1)" class="text-primary font-bold text-lg">+</button>
                                <span class="font-bold w-4 text-center">${item.quantity}</span>
                                <button onclick="changeQty(${item.variantId}, -1)" class="text-red-500 font-bold text-lg">-</button>
                            </div>
                            <div class="text-left">
                                <p class="text-primary font-black text-lg">${(item.price * item.quantity).toLocaleString()} تومان</p>
                            </div>
                        </div>
                    </div>
                </div>`;
        }).join('');

        updateSummary(total);
    }

    function updateSummary(total) {
        document.getElementById('total-price').innerText = total.toLocaleString() + ' تومان';
        const final = total - appliedDiscount;
        document.getElementById('payable-price').innerText = (final > 0 ? final : 0).toLocaleString() + ' تومان';

        if(appliedDiscount > 0) {
            document.getElementById('discount-row').style.display = 'flex';
            document.getElementById('discount-amount').innerText = appliedDiscount.toLocaleString() + ' تومان';
        }
    }

    function changeQty(variantId, delta) {
        let cart = JSON.parse(localStorage.getItem('cart') || '[]');
        const item = cart.find(i => i.variantId == variantId);
        if (item) {
            item.quantity += delta;
            if (item.quantity <= 0) cart = cart.filter(i => i.variantId != variantId);
            localStorage.setItem('cart', JSON.stringify(cart));
            renderCart();
        }
    }

    function applyCoupon() {
        const code = document.getElementById('coupon-code').value;
        const msg = document.getElementById('coupon-msg');
        if(!code) return;

        // Simulating API call for coupon
        if(code === "OFF2024") {
            appliedDiscount = 50000;
            couponCode = code;
            msg.innerText = "کد تخفیف با موفقیت اعمال شد";
            msg.className = "text-[10px] mt-2 text-emerald-500";
            renderCart();
        } else {
            msg.innerText = "کد تخفیف معتبر نیست";
            msg.className = "text-[10px] mt-2 text-red-500";
        }
    }

    async function checkout() {
        const cart = JSON.parse(localStorage.getItem('cart') || '[]');
        if (cart.length === 0) return;

        const token = localStorage.getItem('token');
        if (!token) {
            alert('لطفا ابتدا وارد شوید');
            window.location.href = '/Login';
            return;
        }

        const orderData = {
            items: cart.map(i => ({ productId: i.productId, productVariantId: i.variantId, quantity: i.quantity })),
            couponCode: couponCode
        };

        try {
            const response = await fetch('/api/Order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify(orderData)
            });

            if (response.ok) {
                const res = await response.json();
                alert('سفارش با شماره ' + res.orderId + ' ثبت شد');
                localStorage.removeItem('cart');
                window.location.href = '/OrderSuccess?id=' + res.orderId;
            } else {
                const err = await response.text();
                alert('خطا: ' + err);
            }
        } catch (e) {
            alert('خطای سیستمی');
        }
    }

    document.addEventListener('DOMContentLoaded', renderCart);
</script>
}
