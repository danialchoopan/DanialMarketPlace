@page
@model MarketPlaceCore.Web.Pages.AdminModel
@{
    ViewData["Title"] = "مدیریت سیستم";
}

<div class="flex flex-col lg:flex-row gap-8">
    <aside class="w-full lg:w-64">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-3xl border dark:border-gray-700 space-y-2">
            <a href="/Admin" class="block p-3 rounded-xl bg-primary/10 text-primary font-bold text-sm">داشبورد اصلی</a>
            <a href="#" class="block p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition text-sm">مدیریت محصولات</a>
            <a href="#" class="block p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition text-sm">تنوع‌ها و انبار</a>
            <a href="#" class="block p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition text-sm">کدهای تخفیف</a>
            <a href="#" class="block p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition text-sm">گزارشات فروش</a>
        </div>
    </aside>

    <div class="flex-1">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl font-black">داشبورد مدیریت MarketPlaceCore</h2>
            <button onclick="showAddModal()" class="bg-primary text-white px-6 py-3 rounded-xl font-bold text-sm shadow-lg shadow-primary/20">+ تعریف محصول جدید</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700">
                <p class="text-[10px] uppercase opacity-50 font-bold mb-1">فروش کل</p>
                <p class="text-xl font-black">۸۹۰,۰۰۰,۰۰۰</p>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700">
                <p class="text-[10px] uppercase opacity-50 font-bold mb-1">سفارشات جدید</p>
                <p class="text-xl font-black">۴۲</p>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700">
                <p class="text-[10px] uppercase opacity-50 font-bold mb-1">تنوع‌های ناموجود</p>
                <p class="text-xl font-black text-red-500">۷</p>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border dark:border-gray-700">
                <p class="text-[10px] uppercase opacity-50 font-bold mb-1">نظرات در انتظار</p>
                <p class="text-xl font-black text-orange-500">۱۵</p>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-3xl border dark:border-gray-700 overflow-hidden">
            <table class="w-full text-right text-sm">
                <thead class="bg-gray-50 dark:bg-gray-900/50">
                    <tr>
                        <th class="p-4">شناسه</th>
                        <th class="p-4">نام محصول</th>
                        <th class="p-4">مجموع تنوع‌ها</th>
                        <th class="p-4">میانگین امتیاز</th>
                        <th class="p-4">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var p in Model.Products)
                    {
                        <tr class="border-t dark:border-gray-700 hover:bg-gray-50/50 dark:hover:bg-gray-900/50 transition">
                            <td class="p-4 font-mono opacity-50">#@p.Id</td>
                            <td class="p-4 font-bold">@p.Name</td>
                            <td class="p-4">@p.Variants.Count تنوع</td>
                            <td class="p-4">
                                <span class="text-yellow-500 font-bold">★ @p.AverageRating.ToString("0.0")</span>
                            </td>
                            <td class="p-4">
                                <div class="flex gap-2">
                                    <button class="bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-bold">ویرایش</button>
                                    <button class="bg-purple-50 text-purple-600 px-3 py-1.5 rounded-lg text-xs font-bold">تنوع‌ها</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Placeholder -->
<div id="modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-800 w-full max-w-xl rounded-[2.5rem] p-10 shadow-2xl">
        <h3 class="text-2xl font-black mb-8">افزودن محصول جدید</h3>
        <div class="space-y-4">
            <input type="text" placeholder="نام محصول" class="w-full bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-2xl p-4 outline-none focus:border-primary">
            <textarea placeholder="توضیحات" class="w-full bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-2xl p-4 h-32 outline-none focus:border-primary"></textarea>
            <div class="grid grid-cols-2 gap-4">
                <input type="number" placeholder="قیمت پایه" class="bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-2xl p-4 outline-none">
                <select class="bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-2xl p-4 outline-none">
                    <option>انتخاب دسته بندی</option>
                </select>
            </div>
            <div class="flex gap-4 mt-8">
                <button onclick="hideModal()" class="flex-1 bg-gray-100 dark:bg-gray-700 py-4 rounded-2xl font-bold">انصراف</button>
                <button class="flex-1 bg-primary text-white py-4 rounded-2xl font-bold shadow-lg">ثبت نهایی</button>
            </div>
        </div>
    </div>
</div>

<script>
    function showAddModal() { document.getElementById('modal').classList.replace('hidden', 'flex'); }
    function hideModal() { document.getElementById('modal').classList.replace('flex', 'hidden'); }
</script>
