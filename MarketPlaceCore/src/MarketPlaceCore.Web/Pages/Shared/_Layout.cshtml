<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketPlaceCore - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/tailwind.min.css" />
    <script src="~/js/theme-toggle.js"></script>
    <style>
        body { font-family: Tahoma, Arial, sans-serif; }
        .dark body { background-color: #1a202c; color: #e2e8f0; }
        .light body { background-color: #ffffff; color: #1a202c; }
    </style>
</head>
<body class="transition-colors duration-300">
    <header class="bg-blue-600 dark:bg-blue-900 text-white p-4 shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold">MarketPlaceCore</h1>
            <nav>
                <ul class="flex space-x-4 space-x-reverse">
                    <li><a href="/" class="hover:underline">صفحه اصلی</a></li>
                    <li><a href="/Products" class="hover:underline">محصولات</a></li>
                    <li><a href="/Cart" class="hover:underline">سبد خرید</a></li>
                    <li><button onclick="toggleTheme()" class="bg-gray-200 dark:bg-gray-700 text-black dark:text-white px-3 py-1 rounded">تغییر تم</button></li>
                </ul>
            </nav>
        </div>
    </header>
    <main class="container mx-auto mt-8 p-4">
        @RenderBody()
    </main>
    <footer class="mt-12 p-8 bg-gray-100 dark:bg-gray-800 text-center border-t border-gray-300 dark:border-gray-700">
        <p>تمامی حقوق برای MarketPlaceCore محفوظ است. 2024</p>
    </footer>
    @RenderSection("Scripts", required: false)
</body>
</html>
