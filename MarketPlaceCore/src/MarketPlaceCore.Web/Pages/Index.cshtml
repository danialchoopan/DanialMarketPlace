@page
@model MarketPlaceCore.Web.Pages.IndexModel
@{
    var isEn = Model.HttpContext.Request.Query["lang"] == "en";
    ViewData["Title"] = isEn ? "Home" : "صفحه اصلی";
}

<div class="relative rounded-[3rem] overflow-hidden bg-primary mb-20 h-[600px] flex items-center">
    <!-- Sophisticated Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-tr from-primary via-blue-700 to-indigo-900"></div>
    <div class="absolute inset-0 opacity-10 bg-[url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070')] bg-cover bg-center mix-blend-overlay"></div>

    <div class="container relative z-10 text-white">
        <div class="max-w-3xl">
            <div class="flex items-center gap-3 mb-8">
                <span class="w-12 h-[2px] bg-white/40"></span>
                <span class="text-xs font-black uppercase tracking-[0.3em] text-white/80">@(isEn ? "Enterprise Commerce Solution" : "راهکار تجاری اینترپرایز")</span>
            </div>
            <h1 class="text-7xl font-black mb-8 leading-[1.1] tracking-tighter">
                @(isEn ? "The Future of Digital" : "آینده تجارت دیجیتال") <br/>
                <span class="text-blue-200">@(isEn ? "Marketplace is Here" : "در دستان شماست")</span>
            </h1>
            <p class="text-xl opacity-70 mb-12 font-medium leading-relaxed max-w-2xl">
                @(isEn ? "Empower your business with the most advanced .NET 8.0 e-commerce ecosystem. Scalable, secure, and blazing fast." : "کسب و کار خود را با پیشرفته‌ترین اکوسیستم فروشگاهی دات‌نت ۸.۰ متحول کنید. مقیاس‌پذیر، امن و فوق‌العاده سریع.")
            </p>
            <div class="flex flex-wrap gap-6">
                <a href="/Products?lang=@(isEn ? "en" : "fa")" class="btn-modern bg-white text-primary px-12 py-6 text-xl shadow-2xl shadow-white/10">
                    @(isEn ? "Shop Now" : "همین حالا بخرید")
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="@(isEn ? "" : "rotate-180") ml-2"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="#categories" class="btn-modern bg-white/10 border border-white/20 text-white px-12 py-6 text-xl backdrop-blur-xl hover:bg-white/20 transition-all">
                    @(isEn ? "Explore Categories" : "مشاهده دسته‌بندی‌ها")
                </a>
            </div>
        </div>
    </div>

    <!-- Decorative Element -->
    <div class="absolute bottom-0 @(isEn ? "right-0" : "left-0") w-1/3 h-full opacity-20 pointer-events-none">
        <div class="absolute bottom-[-10%] @(isEn ? "right-[-10%]" : "left-[-10%]") w-[500px] h-[500px] bg-white rounded-full blur-[120px]"></div>
    </div>
</div>

<div class="grid md:grid-cols-4 gap-6 mb-20">
    <div class="bg-white dark:bg-gray-800 p-8 rounded-[2rem] border border-gray-100 dark:border-gray-700 flex items-center gap-4">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div>
            <h4 class="font-bold">@(isEn ? "Fast Shipping" : "ارسال سریع")</h4>
            <p class="text-xs opacity-50">@(isEn ? "Delivery in no time" : "تحویل در کمترین زمان")</p>
        </div>
    </div>
    <div class="bg-white dark:bg-gray-800 p-8 rounded-[2rem] border border-gray-100 dark:border-gray-700 flex items-center gap-4">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center text-green-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
            <h4 class="font-bold">@(isEn ? "Originality" : "ضمانت اصالت")</h4>
            <p class="text-xs opacity-50">@(isEn ? "100% Original Products" : "۱۰۰٪ کالای اصل")</p>
        </div>
    </div>
    <div class="bg-white dark:bg-gray-800 p-8 rounded-[2rem] border border-gray-100 dark:border-gray-700 flex items-center gap-4">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center text-purple-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9"/><path d="M22 4l-11 11-5-5"/></svg>
        </div>
        <div>
            <h4 class="font-bold">@(isEn ? "24/7 Support" : "پشتیبانی ۲۴/۷")</h4>
            <p class="text-xs opacity-50">@(isEn ? "Always by your side" : "همیشه در کنار شما")</p>
        </div>
    </div>
    <div class="bg-white dark:bg-gray-800 p-8 rounded-[2rem] border border-gray-100 dark:border-gray-700 flex items-center gap-4">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-2xl flex items-center justify-center text-orange-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div>
            <h4 class="font-bold">@(isEn ? "Secure Payment" : "پرداخت امن")</h4>
            <p class="text-xs opacity-50">@(isEn ? "Trusted payment gateways" : "درگاه‌های بانکی معتبر")</p>
        </div>
    </div>
</div>

<section id="categories" class="mb-20">
    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-4xl font-black tracking-tight mb-2">@(isEn ? "Popular Categories" : "دسته‌بندی‌های محبوب")</h2>
            <p class="opacity-50 font-medium">@(isEn ? "Quick access to our wide range of products" : "دسترسی سریع به طیف گسترده محصولات ما")</p>
        </div>
    </div>
    <div class="grid lg:grid-cols-3 gap-8">
        @foreach(var cat in Model.Categories)
        {
            <a href="/Products?categoryId=@cat.Id" class="group relative h-80 rounded-[2.5rem] overflow-hidden block">
                <img src="@cat.ImageUrl" class="absolute inset-0 w-full h-full object-cover transition duration-700 group-hover:scale-110" alt="@cat.Name" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-8 right-8 left-8">
                    <h3 class="text-2xl font-bold text-white mb-2">@cat.Name</h3>
                    <div class="w-10 h-1 bg-white rounded-full transition-all duration-300 group-hover:w-20"></div>
                </div>
            </a>
        }
    </div>
</section>
