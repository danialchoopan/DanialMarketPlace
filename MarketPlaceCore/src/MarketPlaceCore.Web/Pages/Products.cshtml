@page
@model MarketPlaceCore.Web.Pages.ProductsModel
@{
    ViewData["Title"] = "فروشگاه محصولات";
}

<div class="flex flex-col md:flex-row gap-8">
    <!-- Sidebar Filters -->
    <aside class="w-full md:w-64 shrink-0">
        <div class="bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 p-6 sticky top-24 shadow-sm">
            <h3 class="font-bold text-lg mb-6 flex items-center gap-2">
                فیلتر محصولات
            </h3>

            <form method="get" class="space-y-6">
                <div>
                    <label class="block text-xs font-bold mb-2 uppercase opacity-50">جستجو</label>
                    <input type="text" name="search" value="@ViewData["CurrentSearch"]" class="w-full bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-xl p-3 text-sm outline-none focus:border-primary transition" placeholder="نام محصول...">
                </div>

                <div>
                    <label class="block text-xs font-bold mb-2 uppercase opacity-50">دسته‌بندی</label>
                    <select name="categoryId" class="w-full bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-xl p-3 text-sm outline-none cursor-pointer">
                        <option value="">همه دسته‌ها</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <button type="submit" class="w-full bg-primary text-white py-3 rounded-xl font-bold shadow-md hover:bg-blue-700 transition">اعمال فیلتر</button>
                <a href="/Products" class="block text-center text-xs text-primary hover:underline">حذف همه فیلترها</a>
            </form>
        </div>
    </aside>

    <!-- Product Grid -->
    <div class="flex-1">
        <div class="mb-6 flex justify-between items-center bg-white dark:bg-gray-800 p-4 rounded-2xl border dark:border-gray-700 shadow-sm">
            <div class="text-sm">
                نمایش <span class="font-bold">@Model.Products.Count()</span> محصول
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var p in Model.Products)
            {
                var minPrice = p.Variants.Any() ? p.Variants.Min(v => v.Price) : 0;
                var totalStock = p.Variants.Sum(v => v.Stock);

                <div class="bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 card group">
                    <div class="h-56 bg-gray-100 dark:bg-gray-700 relative overflow-hidden flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        @if (totalStock <= 0)
                        {
                            <div class="absolute inset-0 bg-black/10 flex items-center justify-center">
                                <span class="bg-white text-black px-4 py-1 rounded-full text-xs font-bold">ناموجود</span>
                            </div>
                        }
                    </div>
                    <div class="p-5">
                        <a href="/ProductDetails/@p.Id" class="block">
                            <h4 class="font-bold text-lg mb-2 group-hover:text-primary transition line-clamp-1">@p.Name</h4>
                        </a>
                        <p class="text-xs opacity-60 mb-4 line-clamp-2 h-8">@p.Description</p>
                        <div class="flex justify-between items-center mt-auto">
                            <div class="flex flex-col">
                                <span class="text-primary font-bold text-lg">@minPrice.ToString("N0") <span class="text-[10px] font-normal">تومان</span></span>
                            </div>
                            <a href="/ProductDetails/@p.Id" class="bg-gray-100 dark:bg-gray-700 hover:bg-primary hover:text-white p-2 rounded-xl transition shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
